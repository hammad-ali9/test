# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/virtualfit

# Security
SECRET_KEY=your-super-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# App
FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=1

# File Upload
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216

# CatVTON try-on server (Colab tunnel URL from colab/catvton_server.ipynb).
# Changes every Colab session. Leave blank — it is auto-discovered from the
# store below. (Can still be overridden via POST /api/tryon/server.)
TRYON_API_URL=

# Auto-discovery store: the Colab notebook PUTs its current tunnel URL here on
# startup; the backend GETs it when a try-on runs. Set once, never touch again.
TRYON_DISCOVERY_URL=https://jsonblob.com/api/jsonBlob/019ef86e-3c96-7d7f-8d36-e14639cf7546
